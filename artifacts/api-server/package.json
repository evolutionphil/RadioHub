{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --experimental-test-module-mocks --test --test-force-exit tests/**/*.test.ts",
    "backfill:tr-logos": "tsx src/scripts/backfill-tr-logos.ts",
    "backfill:tr-tags": "tsx src/scripts/backfill-tr-tags.ts",
    "backfill:logos": "tsx src/scripts/backfill-tr-logos.ts",
    "backfill:tags": "tsx src/scripts/backfill-tr-tags.ts",
    "backfill:verify-cron": "tsx src/scripts/verify-cron.mts",
    "backfill:sample-cohort": "tsx src/scripts/sample-process-cohort.mts",
    "backfill:coverage-snapshots": "tsx src/scripts/backfill-coverage-snapshots.ts",
    "backfill:search-translations": "tsx src/scripts/run-search-translations-seed.ts",
    "cleanup:genre-slugs": "tsx src/scripts/cleanup-malformed-genre-slugs.ts",
    "cleanup:junk-genres": "tsx src/scripts/cleanup-junk-genres.ts",
    "indexnow:task-152": "tsx src/scripts/indexnow-resubmit-task-152.ts",
    "test:seo": "tsx --test test/seo-soft-404.test.ts"
  },
  "dependencies": {
